<?php
session_start();
include '../config/db.php'; // Asumo la ruta de tu conexión MySQLi

// 1. Control de Acceso Estricto (RBAC)
// Verificamos que exista la sesión y que el rol sea exclusivamente 'Owner'
if (!isset($_SESSION['empleado_id']) || $_SESSION['empleado_rol'] !== 'Owner') {
    // Si un Admin u Operador intenta acceder aquí, se le expulsa.
    header("Location: ../public/LoginEmploy.php");
    exit();
}

$mensaje = "";
$tipo_mensaje = "";

if ($_SERVER["REQUEST_METHOD"] == "POST") {
    // Sanitización básica de entradas
    $nombre = trim($_POST['nombre']);
    $usuario = trim($_POST['usuario']);
    $password_raw = $_POST['password'];
    $rol = $_POST['rol'];
    $tiempoSesion = (int)$_POST['tiempoSesion']; // Casteo a entero por seguridad

    // Validación de campos vacíos
    if (empty($nombre) || empty($usuario) || empty($password_raw) || empty($rol) || empty($tiempoSesion)) {
        $mensaje = "Todos los campos son obligatorios.";
        $tipo_mensaje = "error";
    } else {
        // 2. Hashing de Contraseña (Bcrypt)
        // JAMÁS guardes la variable $password_raw directamente en la BD.
        $password_hashed = password_hash($password_raw, PASSWORD_BCRYPT);

        // 3. Sentencia Preparada para evitar SQL Injection
        $sql = "INSERT INTO Empleado (nombre, usuario, password, rol, tiempoSesion) VALUES (?, ?, ?, ?, ?)";
        
        if ($stmt = $conn->prepare($sql)) {
            // 'ssssi' indica el tipo de dato: string, string, string, string, integer
            $stmt->bind_param("ssssi", $nombre, $usuario, $password_hashed, $rol, $tiempoSesion);

            if ($stmt->execute()) {
                $mensaje = "Cuenta de $rol ($usuario) creada con éxito.";
                $tipo_mensaje = "success";
            } else {
                // Manejo del error 1062: Violación de restricción UNIQUE (usuario duplicado)
                if ($conn->errno == 1062) {
                    $mensaje = "Error: El nombre de usuario '$usuario' ya está registrado.";
                } else {
                    $mensaje = "Error crítico en DB: " . $stmt->error;
                }
                $tipo_mensaje = "error";
            }
            $stmt->close();
        } else {
            $mensaje = "Error preparando la consulta: " . $conn->error;
            $tipo_mensaje = "error";
        }
    }
}
?>

<?php
include '../config/db.php';
$mensaje = "";

if ($_SERVER["REQUEST_METHOD"] == "POST") {
    // Sanitización de entradas
    $nombre  = $conn->real_escape_string($_POST['nombre']);
    $usuario = $conn->real_escape_string($_POST['usuario']);
    $correo  = $conn->real_escape_string($_POST['correo']);
    $numero  = $conn->real_escape_string($_POST['numero']);
    
    // ENCRIPTACIÓN: Nunca guardes la clave real, guarda el hash.
    $password_plana = $_POST['password'];
    $password_hash  = password_hash($password_plana, PASSWORD_BCRYPT);

    // Intentar insertar en la base de datos
    $sql = "INSERT INTO UsuarioCliente (usuario, nombre, correo, numero, password) 
            VALUES ('$usuario', '$nombre', '$correo', '$numero', '$password_hash')";

    if ($conn->query($sql) === TRUE) {
        $mensaje = "<div class='alerta exito'>✅ Cuenta creada correctamente. <a href='login.php'>Inicia sesión aquí</a></div>";
    } else {
        // Si el usuario o correo ya existen, MariaDB lanzará un error por el índice UNIQUE
        $mensaje = "<div class='alerta error'>❌ Error: El nombre de usuario o correo ya están registrados.</div>";
    }
}
?>


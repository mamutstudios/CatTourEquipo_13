assoc();

if (!$reservaInfo) {
    // Si la reserva no existe, redirigir al panel principal
    header("Location: panelOperador.php");
    exit();
}

// 4. CONSULTAR LOS PASAJEROS ASOCIADOS A ESTA RESERVA
// Nota: Se asume una tabla intermedia o de detalle llamada 'PasajerosReserva' o similar.
// Ajusta los nombres de las columnas ('nombre', 'apellido', 'numPasaporte', 'idPasajero') según tu esquema.
$sqlPasajeros = "SELECT idPasajero, nombre, apellido, numPasaporte 
                 FROM PasajerosReserva 
                 WHERE idReserva = ?";

$stmtPasajeros = $conn->prepare($sqlPasajeros);
$stmtPasajeros->bind_param("i", $idReservaSel);
$stmtPasajeros->execute();
$resultPasajeros = $stmtPasajeros->get_result();
?>


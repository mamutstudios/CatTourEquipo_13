                    </tr>
                </thead>
                <tbody>
                    <?php if ($resultPasajeros->num_rows > 0): ?>
                        <?php while($pasajero = $resultPasajeros->fetch_assoc()): ?>
                            <tr>
                                <td><strong>#<?php echo $pasajero['idPasajero']; ?></strong></td>
                                <td><?php echo htmlspecialchars($pasajero['nombre'] . ' ' . $pasajero['apellido']); ?></td>
                                <td>📋 <?php echo htmlspecialchars($pasajero['numPasaporte']); ?></td>
                                <td style="text-align: center;">
                                    <!-- Enlace dinámico a la revisión de la documentación específica de ese pasajero -->
                                    <a href="ver_documentos.php?idPasajero=<?php echo $pasajero['idPasajero']; ?>&idReserva=<?php echo $idReservaSel; ?>" class="btn-documentos">📂 Ver Documentos</a>
                                </td>
                            </tr>
                        <?php endwhile; ?>
                    <?php else: ?>
                        <tr><td colspan="4" style="text-align: center; color: #dc3545;">No se encontraron pasajeros registrados para esta reservación.</td></tr>
                    <?php endif; ?>
                </tbody>
            </table>
        </div>
